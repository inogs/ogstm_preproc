#! /bin/bash

#SBATCH --job-name=TAGLIA
#SBATCH -N1
#SBATCH --ntasks-per-node=48
#SBATCH --time=1:00:00
#SBATCH --mem=300gb
#SBATCH --account=OGS_test2528
#SBATCH --partition=g100_usr_prod
##SBATCH --qos=qos_meteo


cd $SLURM_SUBMIT_DIR
. ../profile.inc


source /g100_work/OGS23_PRACE_IT/COPERNICUS/sequence.sh

unset I_MPI_PMI_LIBRARY
export UCX_TLS=ib
export SLURM_PMIX_DIRECT_CONN_UCX=false

INPUTDIR=/g100_work/OGS_test2528/V13C/QUID/SETUP/PREPROC/FORCINGS/ORIG_LINK
OUTPUTDIR=/g100_work/OGS_test2528/V13C/QUID/SETUP/PREPROC/FORCINGS/READY_FOR_MODEL
AVERAGEDIR=/g100_scratch/userexternal/vsciorti/CMCC_PHYS/24h_xarrF/
my_prex_or_die "mpirun -np 48 python slice_files.py -i $INPUTDIR -o $OUTPUTDIR  -f" # -a $AVERAGEDIR


